<div class="chip-stack">
    <div class="chip @ChipClass">
        <span class="chip-value">$@Amount</span>
    </div>
</div>

@code {
    [Parameter] public decimal Amount { get; set; }

    private string ChipClass => Amount switch
    {
        <= 10 => "chip-white",
        <= 25 => "chip-red",
        <= 100 => "chip-green",
        <= 500 => "chip-black",
        _ => "chip-gold"
    };
}
